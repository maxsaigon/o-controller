{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for the main O-Control window",
  "windows": ["main"],
  "permissions": [
    "global-shortcut:allow-is-registered",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-unregister-all",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "args": true, "name": "binaries/o-control-service", "sidecar": true }]
    },
    "shell:allow-spawn",
    "shell:allow-kill",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load"
  ]
}
